# Copiar a .env y completar. NUNCA commitear .env real.

# Postgres (API usa asyncpg; scripts usan DSN psycopg)
PT_DATABASE_URL=postgresql+asyncpg://pt:pt@localhost:5432/peru_transparente
PT_PG_DSN=postgresql://pt:pt@localhost:5432/peru_transparente

# Neo4j
PT_NEO4J_URI=bolt://localhost:7687
PT_NEO4J_USER=neo4j
PT_NEO4J_PASSWORD=peru_transparente

# Redis
PT_REDIS_URL=redis://localhost:6379/0

# IA (intercambiable: claude | openai | gemini)
PT_LLM_PROVIDER=claude
PT_ANTHROPIC_API_KEY=
PT_OPENAI_API_KEY=
PT_GEMINI_API_KEY=

# OAuth GitHub (features avanzadas; lectura pública no requiere login)
PT_GITHUB_CLIENT_ID=
PT_GITHUB_CLIENT_SECRET=

# Frontend (Vite). Dejar VITE_API_URL vacío para modo estático-primero.
VITE_API_URL=
PT_BASE=/peru-transparente/
